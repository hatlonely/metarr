{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@metarr/core": ["../core/src/index.ts"]
    }
  },
  "include": ["app/**/*.ts", "app/**/*.tsx", "src/shared/**/*.ts"],
  "exclude": ["node_modules"]
}
